# Copy to .env and fill in. .env is gitignored; never commit real keys.

# DigitalOcean Gradient AI - THREE separate credentials.
# Confusing them is the #1 debugging time-sink; a 401 usually means the wrong
# key type. See docs/spec.md section 6.

# Serverless inference (Agent 1, Summarizer). Note the underscore in DIGITAL_OCEAN.
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# Agent Platform (Agent 2, Care-Plan Q&A).
DIGITALOCEAN_AGENT_ENDPOINT=
DIGITALOCEAN_AGENT_ACCESS_KEY=
